<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:FitTrackr.MAUI.Localization"
             x:Class="FitTrackr.MAUI.Pages.AddWorkoutPage"
             BackgroundColor="#121212"
             Title="{loc:Translate Key=AddWorkout_Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Label Text="{loc:Translate Key=AddWorkout_Header}"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   Margin="0,10" />

            <Frame CornerRadius="12"
                   BackgroundColor="#1E1E1E"
                   Padding="10"
                   HasShadow="True"
                   BorderColor="#333">
                <Entry x:Name="WorkoutNameEntry"
                       Placeholder="{loc:Translate Key=AddWorkout_NamePlaceholder}"
                       PlaceholderColor="#AAAAAA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       Keyboard="Text"/>
            </Frame>

            <Frame CornerRadius="12"
                   BackgroundColor="#1E1E1E"
                   Padding="10"
                   HasShadow="True"
                   BorderColor="#333">
                <DatePicker x:Name="WorkoutDatePicker"
                            TextColor="White"
                            Format="dd MMM yyyy"
                            MinimumDate="01/01/2000"
                            MaximumDate="12/31/2100"/>
            </Frame>

            <Frame CornerRadius="12"
                   BackgroundColor="#1E1E1E"
                   Padding="10"
                   HasShadow="True"
                   BorderColor="#333">
                <Entry x:Name="DurationMinutes"
                       Placeholder="{loc:Translate Key=AddWorkout_DurationPlaceholder}"
                       PlaceholderColor="#AAAAAA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       Keyboard="Numeric"/>
            </Frame>

            <Frame CornerRadius="12"
                   BackgroundColor="#1E1E1E"
                   Padding="10"
                   HasShadow="True"
                   BorderColor="#333">
                <Picker Title="{loc:Translate Key=AddWorkout_LocationPlaceholder}"
                        x:Name="LocationPicker"
                        TitleColor="#AAAAAA"
                        ItemsSource="{Binding Locations}"
                        ItemDisplayBinding="{Binding LocationName}"
                        TextColor="White"/>
            </Frame>

            <Button Text="{loc:Translate Key=Common_Save}"
                    FontSize="20"
                    TextColor="White"
                    BackgroundColor="Green"
                    CornerRadius="10"
                    HeightRequest="55"
                    Clicked="OnSaveClicked"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
