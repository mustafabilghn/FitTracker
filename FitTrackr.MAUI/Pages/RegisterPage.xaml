<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:FitTrackr.MAUI.Localization"
             x:Class="FitTrackr.MAUI.Pages.RegisterPage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="FitTracker"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="#FF7043"
                   HorizontalOptions="Center"
                   Margin="0,40,0,10"/>

            <Label Text="{loc:Translate Key=Register_Subtitle}"
                   FontSize="16"
                   TextColor="#AAAAAA"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <Frame CornerRadius="12" BackgroundColor="#1E1E1E"
                   Padding="10" HasShadow="True" BorderColor="#333">
                <Entry Placeholder="{loc:Translate Key=Register_UsernamePlaceholder}"
                       PlaceholderColor="#AAAAAA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       Text="{Binding Username}"/>
            </Frame>

            <Frame CornerRadius="12" BackgroundColor="#1E1E1E"
                   Padding="10" HasShadow="True" BorderColor="#333">
                <Entry Placeholder="{loc:Translate Key=Register_EmailPlaceholder}"
                       PlaceholderColor="#AAAAAA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       Keyboard="Email"
                       Text="{Binding Email}"/>
            </Frame>

            <Frame CornerRadius="12" BackgroundColor="#1E1E1E"
                   Padding="10" HasShadow="True" BorderColor="#333">
                <Entry Placeholder="{loc:Translate Key=Register_PasswordPlaceholder}"
                       PlaceholderColor="#AAAAAA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       IsPassword="True"
                       Text="{Binding Password}"/>
            </Frame>

            <Frame CornerRadius="12" BackgroundColor="#1E1E1E"
                   Padding="10" HasShadow="True" BorderColor="#333">
                <Entry Placeholder="{loc:Translate Key=Register_ConfirmPasswordPlaceholder}"
                       PlaceholderColor="#AAAAAA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       IsPassword="True"
                       Text="{Binding ConfirmPassword}"/>
            </Frame>

            <Button Text="{loc:Translate Key=Register_SignUpButton}"
                    FontSize="18"
                    TextColor="White"
                    BackgroundColor="#FF7043"
                    CornerRadius="10"
                    HeightRequest="55"
                    IsEnabled="{Binding IsNotLoading}"
                    Command="{Binding RegisterCommand}"/>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="#FF7043"
                               HorizontalOptions="Center"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="{loc:Translate Key=Register_AlreadyHaveAccount}"
                       TextColor="#AAAAAA"
                       VerticalOptions="Center"/>
                <Label Text="{loc:Translate Key=Register_SignIn}"
                       TextColor="#FF7043"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLoginClicked"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
