<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitTrackr.MAUI.Pages.LoginPage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="FitTracker"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="#FF7043"
                   HorizontalOptions="Center"
                   Margin="0,40,0,10"/>

            <Label Text="Hesabına giriş yap"
                   FontSize="16"
                   TextColor="#AAAAAA"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <Frame CornerRadius="12" BackgroundColor="#1E1E1E"
                   Padding="10" HasShadow="True" BorderColor="#333">
                <Entry Placeholder="E-posta"
                       PlaceholderColor="#AAAAAA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       Keyboard="Email"
                       Text="{Binding Email}"/>
            </Frame>

            <Frame CornerRadius="12" BackgroundColor="#1E1E1E"
                   Padding="10" HasShadow="True" BorderColor="#333">
                <Entry Placeholder="Şifre"
                       PlaceholderColor="#AAAAAA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       IsPassword="True"
                       Text="{Binding Password}"/>
            </Frame>

            <Button Text="Giriş Yap"
                    FontSize="18"
                    TextColor="White"
                    BackgroundColor="#FF7043"
                    CornerRadius="10"
                    HeightRequest="55"
                    IsEnabled="{Binding IsNotLoading}"
                    Command="{Binding LoginCommand}"/>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="#FF7043"
                               HorizontalOptions="Center"/>

            <!-- Şifremi unuttum -->
            <Label Text="Şifremi unuttum"
                   TextColor="#FF7043"
                   FontSize="13"
                   HorizontalOptions="Center"
                   Margin="0,-8,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnForgotPasswordClicked"/>
                </Label.GestureRecognizers>
            </Label>

            <!-- ──── Ayırıcı ──── -->
            <Grid Margin="0,4,0,4">
                <BoxView HeightRequest="1"
                         BackgroundColor="#2E2E2E"
                         VerticalOptions="Center"/>
                <Frame BackgroundColor="#121212"
                       Padding="12,0"
                       HasShadow="False"
                       BorderColor="Transparent"
                       HorizontalOptions="Center"
                       VerticalOptions="Center">
                    <Label Text="veya"
                           TextColor="#666666"
                           FontSize="12"/>
                </Frame>
            </Grid>

            <!-- ──── Google ile Devam Et ──── -->
            <!--
                NOT: Google logo görselini aşağıdaki adımlarla ekleyin:
                1. https://developers.google.com/identity/branding-guidelines adresinden
                   resmi Google "G" logosunu indirin.
                2. Dosyayı "google_logo.png" adıyla Resources/Images/ klasörüne kopyalayın.
                3. .csproj'da <MauiImage Include="Resources\Images\*" /> zaten tanımlı,
                   ek işlem gerekmez.
            -->
            <Frame CornerRadius="10"
                   BackgroundColor="White"
                   Padding="0"
                   HasShadow="True"
                   BorderColor="#DADCE0"
                   IsEnabled="{Binding IsNotLoading}">
                <Grid ColumnDefinitions="44,*,44"
                      HeightRequest="52">

                    <!-- Google "G" logosu -->
                    <Image Grid.Column="0"
                           Source="google_logo.png"
                           HeightRequest="22"
                           WidthRequest="22"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

                    <Label Grid.Column="1"
                           Text="Google ile devam et"
                           TextColor="#3C4043"
                           FontSize="15"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Grid>
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LoginWithGoogleCommand}"/>
                </Frame.GestureRecognizers>
            </Frame>

            <!-- Google yükleniyor göstergesi -->
            <ActivityIndicator IsRunning="{Binding IsGoogleLoading}"
                               IsVisible="{Binding IsGoogleLoading}"
                               Color="#4285F4"
                               HorizontalOptions="Center"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Hesabın yok mu?"
                       TextColor="#AAAAAA"
                       VerticalOptions="Center"/>
                <Label Text="Kayıt ol"
                       TextColor="#FF7043"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterClicked"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
