<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:FitTrackr.MAUI.Localization"
             x:Class="FitTrackr.MAUI.Pages.ForgotPasswordPage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="FitTracker"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="#FF7043"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0"/>

            <Label Text="{loc:Translate Key=ForgotPassword_Title}"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>

            <!-- ── ADIM 1: E-posta ── -->
            <VerticalStackLayout x:Name="StepOneLayout" Spacing="16">

                <Label Text="{loc:Translate Key=ForgotPassword_Step1Hint}"
                       FontSize="14"
                       TextColor="#AAAAAA"
                       HorizontalTextAlignment="Center"
                       Margin="0,8,0,0"/>

                <Frame CornerRadius="12" BackgroundColor="#1E1E1E"
                       Padding="10" HasShadow="True" BorderColor="#333">
                    <Entry x:Name="EmailEntry"
                           Placeholder="{loc:Translate Key=ForgotPassword_EmailPlaceholder}"
                           PlaceholderColor="#AAAAAA"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           Keyboard="Email"/>
                </Frame>

                <Button x:Name="SendCodeButton"
                        Text="{loc:Translate Key=ForgotPassword_SendCodeButton}"
                        FontSize="16"
                        TextColor="White"
                        BackgroundColor="#FF7043"
                        CornerRadius="10"
                        HeightRequest="52"
                        Clicked="OnSendCodeClicked"/>

                <ActivityIndicator x:Name="Step1Indicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="#FF7043"
                                   HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- ── ADIM 2: Kod + Yeni şifre ── -->
            <VerticalStackLayout x:Name="StepTwoLayout" Spacing="16" IsVisible="False">

                <Label x:Name="Step2HintLabel"
                       FontSize="14"
                       TextColor="#AAAAAA"
                       HorizontalTextAlignment="Center"
                       Margin="0,8,0,0"/>

                <Frame CornerRadius="12" BackgroundColor="#1E1E1E"
                       Padding="10" HasShadow="True" BorderColor="#333">
                    <Entry x:Name="CodeEntry"
                           Placeholder="{loc:Translate Key=ForgotPassword_CodePlaceholder}"
                           PlaceholderColor="#AAAAAA"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           Keyboard="Numeric"
                           MaxLength="6"/>
                </Frame>

                <Frame CornerRadius="12" BackgroundColor="#1E1E1E"
                       Padding="10" HasShadow="True" BorderColor="#333">
                    <Entry x:Name="NewPasswordEntry"
                           Placeholder="{loc:Translate Key=ForgotPassword_NewPasswordPlaceholder}"
                           PlaceholderColor="#AAAAAA"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           IsPassword="True"/>
                </Frame>

                <Frame CornerRadius="12" BackgroundColor="#1E1E1E"
                       Padding="10" HasShadow="True" BorderColor="#333">
                    <Entry x:Name="ConfirmPasswordEntry"
                           Placeholder="{loc:Translate Key=ForgotPassword_ConfirmPasswordPlaceholder}"
                           PlaceholderColor="#AAAAAA"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           IsPassword="True"/>
                </Frame>

                <Button x:Name="ResetButton"
                        Text="{loc:Translate Key=ForgotPassword_ResetButton}"
                        FontSize="16"
                        TextColor="White"
                        BackgroundColor="#FF7043"
                        CornerRadius="10"
                        HeightRequest="52"
                        Clicked="OnResetPasswordClicked"/>

                <ActivityIndicator x:Name="Step2Indicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="#FF7043"
                                   HorizontalOptions="Center"/>

                <!-- Kodu tekrar gönder -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,4,0,0">
                    <Label Text="{loc:Translate Key=ForgotPassword_DidNotReceiveCode}"
                           TextColor="#AAAAAA"
                           VerticalOptions="Center"
                           FontSize="13"/>
                    <Label Text="{loc:Translate Key=ForgotPassword_Resend}"
                           TextColor="#FF7043"
                           VerticalOptions="Center"
                           FontSize="13">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnResendCodeClicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
