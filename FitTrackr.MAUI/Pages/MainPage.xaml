<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FitTrackr.MAUI"
             x:Class="FitTrackr.MAUI.MainPage"
             BackgroundColor="#121212">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Label Text="FitTracker"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Start"
                       Margin="0,10" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <!-- Streak Kartı -->
                    <Frame Grid.Column="0"
                           CornerRadius="14"
                           BackgroundColor="#1E1E1E"
                           Padding="16"
                           HasShadow="True"
                           BorderColor="#333">
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Image Source="streak_flame"
                                       HeightRequest="38"
                                       WidthRequest="28"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding Streak}"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="#FF7043"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="Günlük Seri"
                                   FontSize="13"
                                   TextColor="#AAAAAA" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Bu Hafta Kartı -->
                    <Frame Grid.Column="1"
                           CornerRadius="14"
                           BackgroundColor="#1E1E1E"
                           Padding="16"
                           HasShadow="True"
                           BorderColor="#333">
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Image Source="weekly_chart"
                                       HeightRequest="38"
                                       WidthRequest="30"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding WeeklyWorkouts}"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="#4CAF50"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="Bu Hafta"
                                   FontSize="13"
                                   TextColor="#AAAAAA" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Grid Margin="0,20,0,0"
                      HeightRequest="470"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill">

                    <Image Source="fut_card.png"
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill" />

                    <!-- FIFA FUT Kart Düzeni -->
                    <Grid RowDefinitions="230, Auto, 2, *"
                          HorizontalOptions="Fill"
                          VerticalOptions="Fill">

                        <!-- Üst Alan: Sol sütun (rating) + Sağ sütun (avatar) -->
                        <Grid Grid.Row="0"
                              ColumnDefinitions="2*, 3*">

                            <!-- Sol sütun: Toplam KG + Pozisyon + İkon -->
                            <VerticalStackLayout Grid.Column="0"
                                                 VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Margin="30,50,0,120"
                                                 Spacing="3">
                                <Label Text="{Binding TotalMaxKg}"
                                       FontSize="45"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <!-- Sağ sütun: Avatar -->
                            <Frame Grid.Column="1"
                                   WidthRequest="115"
                                   HeightRequest="150"
                                   CornerRadius="8"
                                   Padding="0"
                                   HasShadow="False"
                                   BorderColor="Transparent"
                                   BackgroundColor="Transparent"
                                   HorizontalOptions="Center"
                                   VerticalOptions="End"
                                   Margin="0,0,10,15">
                                <Image Source="{Binding AvatarImageSource}"
                                       Aspect="AspectFill"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill" />
                            </Frame>
                        </Grid>

                        <!-- İsim Satırı -->
                        <Label Grid.Row="1"
                               Text="{Binding FutCardName}"
                               FontSize="19"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               CharacterSpacing="3"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"
                               Margin="20,6,20,6" />

                        <!-- Ayırıcı çizgi -->
                        <BoxView Grid.Row="2"
                                 HeightRequest="1"
                                 Color="#88FFFFFF"
                                 Margin="25,0,25,0" />

                        <!-- İstatistikler: sabit pozisyon — BP=R1Sol, SQ=R1Sağ, DL=R2Sol, BR=R2Sağ, OP=R3Sol -->
                        <VerticalStackLayout Grid.Row="3"
                                             Spacing="0"
                                             Margin="20,10,20,8">

                            <!-- Satır 1: BP (sol) | SQ (sağ) -->
                            <Grid ColumnDefinitions="*,*"
                                  IsVisible="{Binding HasRow1}"
                                  Margin="0,6,0,6">
                                <HorizontalStackLayout Grid.Column="0"
                                                       HorizontalOptions="Center"
                                                       Spacing="4"
                                                       IsVisible="{Binding HasBP}">
                                    <Label Text="{Binding BPValue}"
                                           FontSize="20" FontAttributes="Bold"
                                           TextColor="White" VerticalOptions="End" />
                                    <Label Text="BP"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="#CCCCCC" VerticalOptions="End"
                                           Margin="0,0,0,2" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Column="1"
                                                       HorizontalOptions="Center"
                                                       Spacing="4"
                                                       IsVisible="{Binding HasSQ}">
                                    <Label Text="{Binding SQValue}"
                                           FontSize="20" FontAttributes="Bold"
                                           TextColor="White" VerticalOptions="End" />
                                    <Label Text="SQ"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="#CCCCCC" VerticalOptions="End"
                                           Margin="0,0,0,2" />
                                </HorizontalStackLayout>
                            </Grid>

                            <!-- Satır 2: DL (sol) | BR (sağ) -->
                            <Grid ColumnDefinitions="*,*"
                                  IsVisible="{Binding HasRow2}"
                                  Margin="0,6,0,6">
                                <HorizontalStackLayout Grid.Column="0"
                                                       HorizontalOptions="Center"
                                                       Spacing="4"
                                                       IsVisible="{Binding HasDL}">
                                    <Label Text="{Binding DLValue}"
                                           FontSize="20" FontAttributes="Bold"
                                           TextColor="White" VerticalOptions="End" />
                                    <Label Text="DL"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="#CCCCCC" VerticalOptions="End"
                                           Margin="0,0,0,2" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Column="1"
                                                       HorizontalOptions="Center"
                                                       Spacing="4"
                                                       IsVisible="{Binding HasBR}">
                                    <Label Text="{Binding BRValue}"
                                           FontSize="20" FontAttributes="Bold"
                                           TextColor="White" VerticalOptions="End" />
                                    <Label Text="BR"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="#CCCCCC" VerticalOptions="End"
                                           Margin="0,0,0,2" />
                                </HorizontalStackLayout>
                            </Grid>

                            <!-- Satır 3: OP (sol tek) -->
                            <Grid ColumnDefinitions="*,*"
                                  IsVisible="{Binding HasRow3}"
                                  Margin="0,6,0,6">
                                <HorizontalStackLayout Grid.Column="0"
                                                       HorizontalOptions="Center"
                                                       Spacing="4">
                                    <Label Text="{Binding OPValue}"
                                           FontSize="20" FontAttributes="Bold"
                                           TextColor="White" VerticalOptions="End" />
                                    <Label Text="OP"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="#CCCCCC" VerticalOptions="End"
                                           Margin="0,0,0,2" />
                                </HorizontalStackLayout>
                            </Grid>

                        </VerticalStackLayout>
                    </Grid>
                </Grid>

                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="#FF7043"
                                   HeightRequest="60"
                                   WidthRequest="60"
                                   HorizontalOptions="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
