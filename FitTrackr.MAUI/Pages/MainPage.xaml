<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitTrackr.MAUI.MainPage"
             BackgroundColor="#121212">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Label Text="FitTracker"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Start"
                       Margin="0,10" />

                <Label x:Name="GreetingLabel"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"
                       Margin="0,10,0,0" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Frame Grid.Column="0"
                           CornerRadius="14"
                           BackgroundColor="#1E1E1E"
                           Padding="16"
                           HasShadow="True"
                           BorderColor="#333">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="TotalWorkoutsLabel"
                                   Text="0"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#FF7043" />
                            <Label Text="Antrenman"
                                   FontSize="13"
                                   TextColor="#AAAAAA" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1"
                           CornerRadius="14"
                           BackgroundColor="#1E1E1E"
                           Padding="16"
                           HasShadow="True"
                           BorderColor="#333">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="TotalMinutesLabel"
                                   Text="0 dk"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50" />
                            <Label Text="Toplam Süre"
                                   FontSize="13"
                                   TextColor="#AAAAAA" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Grid Margin="0,20,0,0"
                      HeightRequest="470"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill">

                    <Image Source="fut_card.png"
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill" />

                    <Grid RowDefinitions="270, *"
                          HorizontalOptions="Fill"
                          VerticalOptions="Fill">

                        <!-- ✅ Avatar Bölgesi - Modern Dikdörtgen Tasarım -->
                        <VerticalStackLayout Grid.Row="0"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center"
                                             Spacing="14"
                                             Margin="0,30,0,0">

                            <!-- ✅ Avatar - Yuvarlak Clip Kaldırıldı, Dikdörtgen Portrait Tasarım -->
                            <Frame WidthRequest="110"
                                   HeightRequest="140"
                                   CornerRadius="12"
                                   Padding="0"
                                   HasShadow="True"
                                   BorderColor="#FFD700"
                                   BackgroundColor="Transparent"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Image Source="{Binding AvatarImageSource}"
                                       Aspect="AspectFill"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill" />
                            </Frame>

                            <!-- ✅ Username - Uzun İsimler için LineBreakMode -->
                            <Label Text="{Binding Username}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"
                                   Margin="0,0,0,5" />
                        </VerticalStackLayout>

                        <!-- ✅ Stats Grid - İstatistikler -->
                        <Grid Grid.Row="1"
                              ColumnDefinitions="*,*"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="20"
                              RowSpacing="15"
                              Margin="50,20,50,0"
                              HorizontalOptions="Fill"
                              VerticalOptions="Start">

                            <VerticalStackLayout Grid.Row="0"
                                                 Grid.Column="0"
                                                 Spacing="0"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Label Text="BP" FontSize="12" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding BenchPressMaxWeight}" FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="0"
                                                 Grid.Column="1"
                                                 Spacing="0"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Label Text="SQ" FontSize="12" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding SquatMaxWeight}" FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1"
                                                 Grid.Column="0"
                                                 Spacing="0"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Label Text="DL" FontSize="12" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding DeadliftMaxWeight}" FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1"
                                                 Grid.Column="1"
                                                 Spacing="0"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Label Text="BR" FontSize="12" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding BarbellRowMaxWeight}" FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </Grid>

                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="#FF7043"
                                   HeightRequest="60"
                                   WidthRequest="60"
                                   HorizontalOptions="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
