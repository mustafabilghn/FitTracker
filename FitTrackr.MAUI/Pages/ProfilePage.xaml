<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:FitTrackr.MAUI.Localization"
             xmlns:conv="clr-namespace:FitTrackr.MAUI.Converters"
             x:Class="FitTrackr.MAUI.Pages.ProfilePage"
             Title="{loc:Translate Key=Profile_Title}"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <conv:BoolToActiveColorConverter x:Key="BoolToActiveColorConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="18">

            <!-- Profile Header Card -->
            <Border BackgroundColor="#171717"
                    Stroke="#2A2A2A"
                    StrokeThickness="1"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#33000000"
                            Radius="18"
                            Opacity="0.5"
                            Offset="0,8" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="12"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">

                    <Border WidthRequest="116"
                            HeightRequest="116"
                            StrokeThickness="0"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="58" />
                        </Border.StrokeShape>

                        <Border.Shadow>
                            <Shadow Brush="#66000000"
                                    Radius="18"
                                    Opacity="0.55"
                                    Offset="0,8" />
                        </Border.Shadow>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectAvatarCommand}" />
                        </Border.GestureRecognizers>

                        <Grid>
                            <Image Source="{Binding AvatarImageSource}"
                                   Aspect="AspectFill"
                                   IsVisible="{Binding HasAvatarImage}" />

                            <Grid BackgroundColor="#FF7043"
                                  IsVisible="{Binding HasNoAvatarImage}">
                                <Label Text="{Binding AvatarInitials}"
                                       FontSize="34"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Label Text="{Binding Username}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Profile Info Card -->
            <Border BackgroundColor="#171717"
                    Stroke="#2A2A2A"
                    StrokeThickness="1"
                    Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#33000000"
                            Radius="16"
                            Opacity="0.45"
                            Offset="0,6" />
                </Border.Shadow>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenEditProfileCommand}" />
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{loc:Translate Key=Profile_InfoTitle}"
                                   TextColor="#F2F2F2"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            <Label Text="{loc:Translate Key=Profile_InfoSubtitle}"
                                   FontSize="12"
                                   TextColor="#9C9C9C" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="14">

                        <Border Grid.ColumnSpan="2" BackgroundColor="#1C1C1C" StrokeThickness="0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Text="{loc:Translate Key=Profile_Username}" TextColor="#BDBDBD" FontSize="12" />
                                <Label Grid.Row="1" Text="{Binding Username}" TextColor="White" FontSize="15" />         
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" BackgroundColor="#1C1C1C" StrokeThickness="0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Text="{loc:Translate Key=Profile_Gender}" TextColor="#BDBDBD" FontSize="12" />
                                <Label Grid.Row="1" Text="{Binding SelectedGender}" TextColor="White" FontSize="15" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#1C1C1C" StrokeThickness="0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Text="{loc:Translate Key=Profile_Goal}" TextColor="#BDBDBD" FontSize="12" />
                                <Label Grid.Row="1" Text="{Binding SelectedGoal}" TextColor="White" FontSize="15" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" BackgroundColor="#1C1C1C" StrokeThickness="0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Text="{loc:Translate Key=Profile_Height}" TextColor="#BDBDBD" FontSize="12" />
                                <Label Grid.Row="1" Text="{Binding HeightCm}" TextColor="White" FontSize="15" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="1" BackgroundColor="#1C1C1C" StrokeThickness="0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Text="{loc:Translate Key=Profile_Weight}" TextColor="#BDBDBD" FontSize="12" />
                                <Label Grid.Row="1" Text="{Binding WeightKg}" TextColor="White" FontSize="15" />
                            </Grid>
                        </Border>

                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Language Card -->
            <Border BackgroundColor="#171717"
                    Stroke="#2A2A2A"
                    StrokeThickness="1"
                    Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#33000000"
                            Radius="16"
                            Opacity="0.45"
                            Offset="0,6" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="14">
                    <Label Text="{loc:Translate Key=Profile_Language}"
                           TextColor="#F2F2F2"
                           FontSize="16"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="Türkçe"
                                Command="{Binding SetLanguageCommand}"
                                CommandParameter="tr"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="48">
                            <Button.BackgroundColor>
                                <Binding Path="IsTurkishSelected" Converter="{StaticResource BoolToActiveColorConverter}" />
                            </Button.BackgroundColor>
                        </Button>

                        <Button Grid.Column="1"
                                Text="English"
                                Command="{Binding SetLanguageCommand}"
                                CommandParameter="en"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="48">
                            <Button.BackgroundColor>
                                <Binding Path="IsEnglishSelected" Converter="{StaticResource BoolToActiveColorConverter}" />
                            </Button.BackgroundColor>
                        </Button>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Account Actions Card -->
            <Border BackgroundColor="#171717"
                    Stroke="#2A2A2A"
                    StrokeThickness="1"
                    Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#33000000"
                            Radius="16"
                            Opacity="0.45"
                            Offset="0,6" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="14">
                    <Label Text="{loc:Translate Key=Profile_AccountTitle}"
                           TextColor="#F2F2F2"
                           FontSize="16"
                           FontAttributes="Bold" />

                    <Button Text="{loc:Translate Key=Profile_SignOut}"
                            Command="{Binding LogoutCommand}"
                            BackgroundColor="#E53935"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="48" />

                    <Button Text="{loc:Translate Key=Profile_DeleteAccount}"
                            Command="{Binding ConfirmDeleteAccountCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#FF6B6B"
                            BorderColor="#FF6B6B"
                            BorderWidth="1"
                            CornerRadius="14"
                            HeightRequest="48" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
