<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FitTrackr.MAUI.Controls"
             x:Class="FitTrackr.MAUI.Pages.ProfilePage"
             Title="ProfilePage"
             BackgroundColor="#121212">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="30,30,30,120" Spacing="20" VerticalOptions="Center">
                <Frame WidthRequest="90"
                       HeightRequest="90"
                       CornerRadius="45"
                       BackgroundColor="#FF7043"
                       HorizontalOptions="Center"
                       Padding="0"
                       HasShadow="False"
                       BorderColor="Transparent">
                    <Label Text="{Binding UsernameInitial}"
                           FontSize="36"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>
                <Button Text="Çıkış Yap"
                        FontSize="16"
                        TextColor="White"
                        BackgroundColor="#E53935"
                        CornerRadius="10"
                        HeightRequest="50"
                        Margin="0,40,0,0"
                        Command="{Binding LogoutCommand}"/>

                <Button Text="Hesabı ve Verileri Sil"
                        Command="{Binding ConfirmDeleteAccountCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#E53935"
                        BorderColor="#E53935"
                        BorderWidth="1"
                        FontSize="14"
                        Margin="0,10,0,0"
                        CornerRadius="10"
                        HeightRequest="45"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              HeightRequest="78"
              ColumnDefinitions="*,Auto,*"
              Margin="0,0,0,8">
            <controls:FitBotLaunchButton
                Grid.Column="1"
                HorizontalOptions="Center"
                VerticalOptions="End"
                TranslationY="-14"
                ZIndex="10" />
        </Grid>
    </Grid>
</ContentPage>
