<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Name="ThisPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitTrackr.MAUI.Pages.WorkoutDetailPage"
             BackgroundColor="#121212">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,20,20,120" Spacing="20">

                <Label Text="{Binding Workout.WorkoutName}"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0"/>

                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">

                    <Border Stroke="#4CAF50" StrokeThickness="1" Padding="8,3" StrokeShape="RoundRectangle 10">
                        <Label Text="{Binding Workout.DurationMinutes,StringFormat='⏱ {0} dk'}"
                           FontSize="14"
                           TextColor="#4CAF50"/>
                    </Border>

                    <Border Stroke="#FF7043" StrokeThickness="1" Padding="8,3" StrokeShape="RoundRectangle 10">
                        <Label Text="{Binding Workout.Location.LocationName,StringFormat='📍 {0}'}"
                           FontSize="14"
                           TextColor="#FF7043"/>
                    </Border>

                    <Border Stroke="#2196F3" StrokeThickness="1" Padding="8,3" StrokeShape="RoundRectangle 10">
                        <Label Text="{Binding Workout.WorkoutDateText,StringFormat='📅 {0}'}"
                           FontSize="14"
                           TextColor="#2196F3"/>
                    </Border>
                </HorizontalStackLayout>

                <Label Text="Egzersizler"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White"
                   Margin="0,20,0,10"/>

                <CollectionView ItemsSource="{Binding Exercises}"
                            SelectionMode="None"
                            VerticalScrollBarVisibility="Never">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItem Text="Sil"
                                                   BackgroundColor="#E53935"
                                                   Command="{Binding Source={x:Reference ThisPage},Path=BindingContext.DeleteExerciseCommand}"
                                                   CommandParameter="{Binding Id}"/>
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <Frame Padding="15"
                                       CornerRadius="14"
                                       BackgroundColor="#1E1E1E"
                                       HasShadow="True"
                                       BorderColor="#333">
                                    <VerticalStackLayout Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleExerciseCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>

                                            <Label Text="{Binding ExerciseName}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />

                                            <Label Grid.Column="1"
                                                   Text="{Binding Intensity.Level,StringFormat='Yoğunluk: {0}'}"
                                                   FontSize="14"
                                                   TextColor="#FF7043"
                                                   HorizontalOptions="End"
                                                   VerticalOptions="Center" />
                                        </Grid>

                                        <CollectionView ItemsSource="{Binding ExerciseSets}"
                                                        SelectionMode="None"
                                                        IsVisible="{Binding IsExpanded}">
                                            <CollectionView.ItemsLayout>
                                                <LinearItemsLayout Orientation="Vertical"
                                                                   ItemSpacing="6" />
                                            </CollectionView.ItemsLayout>

                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Frame Padding="8"
                                                           CornerRadius="10"
                                                           BackgroundColor="#252525"
                                                           HasShadow="False"
                                                           BorderColor="#333">
                                                        <Grid ColumnDefinitions="Auto,*">
                                                            <Label Text="{Binding SetNumber, StringFormat='Set {0}'}"
                                                                   FontSize="14"
                                                                   TextColor="#CCCCCC" />

                                                            <Label Grid.Column="1"
                                                                   Text="{Binding DisplayText}"
                                                                   FontSize="14"
                                                                   TextColor="#FFFFFF"
                                                                   HorizontalOptions="End"
                                                                   VerticalOptions="Center" />
                                                        </Grid>
                                                    </Frame>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>

                                        <Label Text="{Binding Notes,StringFormat='Notlar: {0}'}"
                                               FontSize="14"
                                               TextColor="#FF7043"
                                               IsVisible="{Binding IsExpanded}" />

                                    </VerticalStackLayout>
                                </Frame>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
        
        <Button 
    Text="+" 
    Clicked="OnAddExerciseClicked"
    FontSize="32"
    TextColor="White"
    BackgroundColor="#FF7043"
    CornerRadius="40"
    WidthRequest="70"
    HeightRequest="70"
    HorizontalOptions="End"
    VerticalOptions="End"
    Margin="20"/>
    </Grid>
</ContentPage>  
    