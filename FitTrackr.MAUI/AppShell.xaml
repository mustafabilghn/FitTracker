<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FitTrackr.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FitTrackr.MAUI"
    xmlns:pages="clr-namespace:FitTrackr.MAUI.Pages"
    xmlns:loc="clr-namespace:FitTrackr.MAUI.Localization"
    Title="FitTrackr.MAUI">

    <TabBar>
        <ShellContent Title="{loc:Translate Key=AppShell_Home}"
                      Shell.NavBarIsVisible="False"
                      Icon="home.png"
                      ContentTemplate="{DataTemplate local:MainPage}"
                      Route="MainPage"/>
        <ShellContent Title="{loc:Translate Key=AppShell_Workouts}"
                      Shell.NavBarIsVisible="False"
                      Icon="workouts.png"
                      ContentTemplate="{DataTemplate pages:WorkoutListPage}"
                      Route="WorkoutListPage"/>
        <ShellContent Title="{loc:Translate Key=AppShell_Reports}"
                      Shell.NavBarIsVisible="False"
                      Icon="progress.svg"
                      ContentTemplate="{DataTemplate pages:ProgressPage}"
                      Route="ProgressPage"/>
        <ShellContent Title="FitBot"
                      Shell.NavBarIsVisible="False"
                      Icon="bot.png"
                      ContentTemplate="{DataTemplate pages:FitBotPage}"
                      Route="FitBotPage"/>
        <ShellContent Title="{loc:Translate Key=AppShell_Profile}"
                      Shell.NavBarIsVisible="False"
                      Icon="profile.png"
                      ContentTemplate="{DataTemplate pages:ProfilePage}"
                      Route="ProfilePage"/>
    </TabBar>
</Shell>
